      (check x 5 1))))

(test "bitwise or: 8|4 = 12"
  :run-once
  (begin
    (let ((x (or 8 4)))
      (check x 12 1))))

(test "bitwise xor: 15^8 = 7"
  :run-once
  (begin
    (let ((x (xor 15 8)))
      (check x 7 1))))

(test "left shift: 1<<3 = 8"
  :run-once
  (begin
