(test "chained addition evaluates correctly"
  :run-once
  (begin
    (let ((x (+ 3 4 5)))
      (check x 12 1))))

(test "compound expr in mark: timer * 2"
  :run-once
  (begin
    (let ((timer 10) (result 0))
      (set! result (* timer 2))
      (check result 20 1))))

(test "nested compound exprs: (+ (* 2 3) (- 10 5))"
  :run-once
  (begin
    (let ((x (+ (* 2 3) (- 10 5))))
      (check x 11 1))))

(test "unary negation: (- 5) = -5"
  :run-once
  (begin
    (let ((x 5))
      (set! x (- x))
      (check x -5 1))))

(test "unary negation in nested let"
  :run-once
  (begin
    (let ((x 5))
      (let ((y (- x)))
        (check y -5 1)))))

(test "nested let scopes preserve values"
  :run-once
  :ant-x 5
  :ant-y 5
  (begin
    (let ((a (sense food))
          (b (sense wall))
          (c (sense nest)))
      ; On blank map at 5,5 (away from nest at 16,16) all should be 0
      (check a 0 1)
      (check b 0 2)
      (check c 0 3))))

(test "let shadowing: inner x shadows outer"
  :run-once
  (begin
    (let ((x 5))
      (let ((x 10))
        (check x 10 1)))))

(test "let with multiple sensing bindings"
  :run-once
  :ant-x 16
  :ant-y 16
  (begin
    (let ((a (sense food))
          (b (sense wall))
          (c (carrying?)))
      (check a 0 1)
      (check b 0 2)
      (check c 0 3))))

(test "let binding as global-style var: dx + 1"
  :run-once
  (begin
    (let ((dx 0) (dy 0))
      (set! dx (+ dx 1))
      (check dx 1 1))))

(test "set! with compound expression: (* 2 3) + 4"
  :run-once
  (begin
    (let ((x 0))
      (set! x (+ (* 2 3) 4))
      (check x 10 1))))

(test "double negation: (- (- 5)) = 5"
  :run-once
  (begin
    (let ((x 5))
      (let ((y (- (- x))))
        (check y 5 1)))))

(test "arithmetic with same operands: x + x"
  :run-once
  (begin
    (let ((x 5))
      (let ((y (+ x x)))
        (check y 10 1)))))

; ─── Comparison operators ───────────────────────────────────
; (Migrated from antlisp.test.js — constant-input tests that
; a smart optimizer folds, so we test runtime values instead)

(test "greater than: 5 > 3"
  :run-once
  (begin
    (let ((x 5) (r 0))
      (if (> x 3) (set! r 1) (set! r 2))
      (check r 1 1))))

(test "less than: 2 < 5"
  :run-once
  (begin
    (let ((x 2) (r 0))
      (if (< x 5) (set! r 1) (set! r 2))
      (check r 1 1))))

(test "greater or equal: 5 >= 5"
  :run-once
  (begin
    (let ((x 5) (r 0))
      (if (>= x 5) (set! r 1) (set! r 2))
      (check r 1 1))))

(test "less or equal: 5 <= 5"
  :run-once
  (begin
    (let ((x 5) (r 0))
      (if (<= x 5) (set! r 1) (set! r 2))
      (check r 1 1))))

(test "not equal: 5 != 0"
  :run-once
  (begin
    (let ((x 5) (r 0))
      (if (!= x 0) (set! r 1) (set! r 2))
      (check r 1 1))))

(test "comparison as value: (> 5 3) = 1"
  :run-once
  (begin
    (let ((result (> 5 3)))
      (check result 1 1))))

