; ─── Cond with set! ────────────────────────────────────────

(test "cond with set! updates variable: dir=2 increments dx"
  :run-once
  (begin
    (let ((dx 0) (dy 0) (dir 2))
      (cond ((= dir 1) (set! dy (- dy 1)))
            ((= dir 2) (set! dx (+ dx 1)))
            ((= dir 3) (set! dy (+ dy 1)))
            ((= dir 4) (set! dx (- dx 1))))
      (check dx 1 1))))

(test "cond with set! updates variable: dir=3 increments dy"
  :run-once
  (begin
    (let ((dx 0) (dy 0) (dir 3))
      (cond ((= dir 1) (set! dy (- dy 1)))
            ((= dir 2) (set! dx (+ dx 1)))
            ((= dir 3) (set! dy (+ dy 1)))
            ((= dir 4) (set! dx (- dx 1))))
      (check dy 1 1))))

(test "cond set! in loop: dx accumulates over 3 east moves"
  :ticks 3
  :run-once
  (begin
    (let ((dx 0) (dy 0))
      (dotimes (i 3)
        (set! dx (+ dx 1))
        (move e))
      (check dx 3 1))))

; ─── Assert expression (new syntax) ───────────────────────

(test "assert: simple constant"
  :run-once
  (begin
    (check (+ 1 2) 3 1)))

(test "assert: variable after set!"
  :run-once
  (begin
    (let ((x 0))
      (set! x 5)
      (check x 5 1))))

(test "assert: cond updates dx"
  :run-once
  (begin
    (let ((dx 0) (dy 0) (dir 2))
      (cond ((= dir 1) (set! dy (- dy 1)))
            ((= dir 2) (set! dx (+ dx 1)))
            ((= dir 3) (set! dy (+ dy 1)))
            ((= dir 4) (set! dx (- dx 1))))
      (check dx 1 1))))

(test "assert: compound expression"
  :run-once
  (begin
    (let ((x 3) (y 4))
      (check (+ x y) 7 1))))

; ─── Phi-node cond/set! regression ──────────────────────────────
; When a cond with set! on multiple outer variables is nested inside
; an if-branch (creating an outer join point with phi nodes), the
; codegen must not clobber the just-computed value with the
; "copy unchanged variable" move.

(test "cond set! inside if: dir=4 decrements dx, preserves dy"
  :run-once
  (begin
    (let ((dx 5) (dy 10))
      ; carrying? returns 0 on blank map, so (+ 0 4) = 4
      (let ((dir (+ (carrying?) 4)))
        (if (!= dir 0)
          (cond ((= dir 1) (set! dy (- dy 1)))
                ((= dir 2) (set! dx (+ dx 1)))
                ((= dir 3) (set! dy (+ dy 1)))
                ((= dir 4) (set! dx (- dx 1))))
          (begin)))
      (check dx 4 1)
      (check dy 10 2))))

(test "cond set! inside if: dir=1 decrements dy, preserves dx"
  :run-once
  (begin
    (let ((dx 5) (dy 10))
      (let ((dir (+ (carrying?) 1)))
        (if (!= dir 0)
          (cond ((= dir 1) (set! dy (- dy 1)))
                ((= dir 2) (set! dx (+ dx 1)))
                ((= dir 3) (set! dy (+ dy 1)))
                ((= dir 4) (set! dx (- dx 1))))
          (begin)))
      (check dx 5 1)
      (check dy 9 2))))

; ─── dolist ──────────────────────────────────────────────────

(test "dolist: iterates over values"
  :run-once
  (begin
    (let ((sum 0))
      (dolist (x (values 10 20 30))
        (set! sum (+ sum x)))
      (check sum 60 1))))

(test "dolist: break exits early"
  :run-once
  (begin
    (let ((sum 0))
      (dolist (x (values 1 2 3 4 5))
        (when (= x 3) (break))
        (set! sum (+ sum x)))
      (check sum 3 1))))  ; 1+2

(test "dolist: continue skips iteration"
  :run-once
  (begin
    (let ((sum 0))
      (dolist (x (values 1 2 3 4 5))
        (when (= x 3) (continue))
        (set! sum (+ sum x)))
      (check sum 12 1))))  ; 1+2+4+5

(test "dolist: empty values is no-op"
  :run-once
  (begin
    (let ((x 42))
      (dolist (v (values))
        (set! x 0))
      (check x 42 1))))

; ─── Unrolled dotimes ────────────────────────────────────────────

(test "dotimes unrolled: basic count"
  :run-once
  (begin
    (let ((count 0))
      (dotimes (i 3)
        (set! count (+ count 1)))
      (check count 3 1))))

(test "dotimes unrolled: i has correct value each iteration"
  :run-once
  (begin
    (let ((sum 0))
      (dotimes (i 4)
        (set! sum (+ sum i)))
      (check sum 6 1))))  ; 0+1+2+3

(test "dotimes unrolled: break exits early"
  :run-once
  (begin
    (let ((count 0))
      (dotimes (i 10)
        (set! count (+ count 1))
        (when (= count 3) (break)))
      (check count 3 1))))

(test "dotimes unrolled: continue skips to next iteration"
  :run-once
  (begin
    (let ((count 0))
      (dotimes (i 5)
        (when (= i 2) (continue))
        (set! count (+ count 1)))
      (check count 4 1))))

; ─── Phi-node cond/set! regression ──────────────────────────────
(test "cond set! inside if: dir=2 increments dx, preserves dy"
  :run-once
  (begin
    (let ((dx 5) (dy 10))
      (let ((dir (+ (carrying?) 2)))
        (if (!= dir 0)
          (cond ((= dir 1) (set! dy (- dy 1)))
                ((= dir 2) (set! dx (+ dx 1)))
                ((= dir 3) (set! dy (+ dy 1)))
                ((= dir 4) (set! dx (- dx 1))))
          (begin)))
      (check dx 6 1)
      (check dy 10 2))))
