; ═══════════════════════════════════════════════════════════════
; AntLisp Unit Tests
; ═══════════════════════════════════════════════════════════════
;
; Run with: node compiler/antlisp.unit.js compiler/antlisp.unit.alisp
; Or:       argc unit compiler/antlisp.unit.alisp
;
; Syntax:
;   (test "name" [:opt val | :flag]* (begin ...) ...)
;
; The (begin ...) is the program body.  Use (check expr expected code)
; for inline assertions — triggers (abort! code) if expr != expected.
; :run-once implies :ticks 1.

; ─── Assertion helpers ────────────────────────────────────────

; (check expr expected code) — abort with code if expr != expected
(defmacro check (expr expected code)
  (when (!= expr expected) (abort! code)))

; Harness-replacement macros using magic registers
(defmacro assert-at (ex ey code-x code-y)
  (when (!= (reg rD_PX) ex) (abort! code-x))
  (when (!= (reg rD_PY) ey) (abort! code-y)))

(defmacro assert-tick (expected code)
  (when (!= (reg rD_CL) expected) (abort! code)))

(defmacro assert-pc (expected code)
  (when (!= (reg rD_PC) expected) (abort! code)))

; ─── Basic register operations ───────────────────────────────

(test "let and set! updates register"
  :run-once
  (begin
    (let ((x 0))
      (set! x 1)
      (check x 1 1))))

(test "user example: let x 0, set! x 1"
  :run-once
  (begin
    (let ((x 0))
      (set! x 1)
      (check x 1 1))))

(test "let preserves initial value without mutation"
  :run-once
  (begin
    (let ((x 42))
      (check x 42 1))))

(test "multiple let bindings are independent"
  :run-once
  (begin
    (let ((a 1) (b 2) (c 3))
      (check a 1 1)
      (check b 2 2)
      (check c 3 3))))

(test "let*: sequential binding"
  :run-once
  (begin
    (let* ((x 1) (y (+ x 1)))
      (check y 2 1))))

(test "let: parallel binding sees outer scope"
  :run-once
  (begin
    (let ((x 0))
      (let ((x 10) (y x))
        (check y 0 1)))))

(test "let: set! propagates to outer scope"
  :run-once
  (begin
    (let ((x 0))
      (let ((a 1))
        (set! x 5))
      (check x 5 1))))

; ─── Arithmetic ──────────────────────────────────────────────

(test "addition: a + b into c"
  :run-once
  (begin
    (let ((a 3) (b 4) (c 0))
      (set! c (+ a b))
      (check c 7 1))))

(test "subtraction: x - 3"
  :run-once
  (begin
    (let ((x 10))
      (set! x (- x 3))
      (check x 7 1))))

(test "multiplication: x * 7"
  :run-once
  (begin
    (let ((x 6))
      (set! x (* x 7))
      (check x 42 1))))

(test "division: x / 4"
  :run-once
  (begin
    (let ((x 20))
      (set! x (/ x 4))
      (check x 5 1))))

(test "modulo: 17 mod 5"
  :run-once
  (begin
    (let ((x 0))
      (set! x (mod 17 5))
      (check x 2 1))))

(test "chained addition: 1+2+3+4"
  :run-once
  (begin
    (let ((x 0))
      (set! x (+ 1 2 3 4))
      (check x 10 1))))

(test "bitwise and: 15 and 6 = 6"
  :run-once
  (begin
    (let ((x 0))
      (set! x (and 15 6))
      (check x 6 1))))

(test "bitwise or: 8 or 5 = 13"
  :run-once
  (begin
    (let ((x 0))
      (set! x (or 8 5))
      (check x 13 1))))

(test "left shift: 1 << 3 = 8"
  :run-once
  (begin
    (let ((x 1))
      (set! x (lshift x 3))
      (check x 8 1))))

(test "right shift: 16 >> 2 = 4"
  :run-once
  (begin
    (let ((x 16))
      (set! x (rshift x 2))
      (check x 4 1))))

(test "unary negation: (- x) on 5 = -5"
  :run-once
  (begin
    (let ((x 5))
      (set! x (- x))
      (check x -5 1))))

(test "comparison operators on variable"
  :run-once
  (begin
    (let ((x 10))
      (check (> x 5) 1 1)
      (check (< x 20) 1 2)
      (check (>= x 10) 1 3)
      (check (<= x 10) 1 4)
      (check (!= x 9) 1 5))))

; ─── Named register assertions ───────────────────────────────

(test "counter set to 99"
  :run-once
  (begin
    (let ((counter 0))
      (set! counter 99)
      (check counter 99 1))))

(test "score with comparison"
  :run-once
  (begin
    (let ((score 50))
      (set! score (+ score 10))
      (check (> score 55) 1 1)
      (check score 60 2))))

; ─── Conditionals ────────────────────────────────────────────

(test "if: then branch taken when condition true"
  :run-once
  (begin
    (let ((x 1) (result 0))
      (if (= x 1)
        (set! result 10)
        (set! result 20))
      (check result 10 1))))

(test "if: else branch taken when condition false"
  :run-once
  (begin
    (let ((x 5) (result 0))
      (if (= x 1)
        (set! result 10)
        (set! result 20))
      (check result 20 1))))

(test "cond: correct branch matched"
  :run-once
  (begin
    (let ((x 3) (result 0))
      (cond ((= x 1) (set! result 100))
            ((= x 2) (set! result 200))
            ((= x 3) (set! result 300))
            (else    (set! result 999)))
      (check result 300 1))))

(test "cond: else branch taken when no match"
  :run-once
  (begin
    (let ((x 99) (result 0))
      (cond ((= x 1) (set! result 1))
            ((= x 2) (set! result 2))
            (else    (set! result 42)))
      (check result 42 1))))

(test "when: body runs when condition true"
  :run-once
  (begin
    (let ((x 5) (flag 0))
      (when (> x 3)
        (set! flag 1))
      (check flag 1 1))))

(test "when: body skipped when condition false"
  :run-once
  (begin
    (let ((x 1) (flag 0))
      (when (> x 3)
        (set! flag 1))
      (check flag 0 1))))

(test "unless: body skipped when condition true"
  :run-once
  (begin
    (let ((x 5) (flag 0))
      (unless (> x 3)
        (set! flag 1))
      (check flag 0 1))))

(test "unless: body runs when condition false"
  :run-once
  (begin
    (let ((x 1) (flag 0))
      (unless (> x 3)
        (set! flag 1))
      (check flag 1 1))))

; ─── Loops ───────────────────────────────────────────────────

(test "dotimes: loops exactly N times"
  :run-once
  (begin
    (let ((count 0))
      (dotimes (i 5)
        (set! count (+ count 1)))
      (check count 5 1))))

(test "while: loops while condition holds"
  :run-once
  (begin
    (let ((x 10) (steps 0))
      (while (> x 5)
        (set! x (- x 1))
        (set! steps (+ steps 1)))
      (check x 5 1)
      (check steps 5 2))))

(test "loop with break exits"
  :run-once
  (begin
    (let ((x 0))
      (loop
        (set! x (+ x 1))
        (if (= x 3)
          (break)))
      (check x 3 1))))

(test "loop with continue skips rest of body"
  :run-once
  (begin
    (let ((i 0) (evens 0))
      (while (< i 10)
        (set! i (+ i 1))
        (if (!= (mod i 2) 0)
          (continue))
        (set! evens (+ evens 1)))
      (check evens 5 1))))

; ─── Multi-tick accumulation ─────────────────────────────────
;
; (loop ...(move random)) runs the body once per tick: each MOVE
; ends the tick, registers survive, the loop resumes next tick.

(test "register accumulates across ticks via loop+move"
  :ticks 3
  :run-once
  (begin
    (let ((count 0))
      (dotimes (i 3)
        (set! count (+ count 1))
        (move random))
      (check count 3 1))))

(test "register accumulates +2 per tick over 5 ticks"
  :ticks 5
  :run-once
  (begin
    (let ((total 0))
      (dotimes (i 5)
        (set! total (+ total 2))
        (move random))
      (check total 10 1))))

; ─── Food / action tests ─────────────────────────────────────

(test "ant not carrying food initially"
  :run-once
  (begin
    (check (carrying?) 0 1)
    (move n)))

(test "pickup food when standing on it"
  :ticks 3
  :ant-x 16
  :ant-y 16
  :place-food 16 16
  (begin
    (loop
      (pickup)
      (check (carrying?) 1 1))))

(test "food collected counter increases after drop at nest"
  :ticks 20
  :ant-x 20
  :ant-y 16
  :place-food 20 16
  (begin
    (loop
      (pickup)
      (move w)
      (move w)
      (move w)
      (move w)
      (drop)
      ; rD_FD is food collected at tick start — after a drop+next tick it should be >= 0
      (check (>= (reg rD_FD) 0) 1 1))))

; ─── Tick assertion ──────────────────────────────────────────

(test "rD_CL: tick register increments each tick"
  :ticks 3
  :run-once
  (begin
    (let ((seen0 0) (seen1 0) (seen2 0))
      (set! seen0 (reg rD_CL))
      (move n)
      (set! seen1 (reg rD_CL))
      (move n)
      (set! seen2 (reg rD_CL))
      (move n)
      (check seen0 0 1)
      (check seen1 1 2)
      (check seen2 2 3))))

; ─── Sensing smoke tests ─────────────────────────────────────

(test "smell ch_red returns 0 on blank map"
  :run-once
  (begin
    (let ((dir 5))
      (set! dir (smell ch_red))
      (check dir 0 1))))

(test "sense food returns 0 when no adjacent food"
  :run-once
  (begin
    (let ((dir 5))
      (set! dir (sense food))
      (check dir 0 1))))

(test "carrying? returns 0 when not carrying"
  :run-once
  (begin
    (let ((c 255))
      (set! c (carrying?))
      (check c 0 1))))

; ─── Integration ─────────────────────────────────────────────

(test "forager pattern: dx/dy accumulate each tick"
  :ticks 4
  :run-once
  (begin
    (let ((dx 0) (dy 0))
      (dotimes (i 4)
        (set! dx (+ dx 1))
        (set! dy (- dy 1))
        (move random))
      (check dx 4 1)
      (check dy -4 2))))

; ─── Short-circuit and/or in conditional contexts ──────────────

;; --- short-circuit and ---
(test "and short-circuit: both true takes then"
  :run-once
  (begin (let ((r 0))
    (if (and (= 1 1) (= 2 2)) (set! r 10) (set! r 20))
    (check r 10 1))))

(test "and short-circuit: first false takes else"
  :run-once
  (begin (let ((r 0))
    (if (and (= 1 2) (= 2 2)) (set! r 10) (set! r 20))
    (check r 20 1))))

(test "and short-circuit: second false takes else"
  :run-once
  (begin (let ((r 0))
    (if (and (= 1 1) (= 2 3)) (set! r 10) (set! r 20))
    (check r 20 1))))

(test "and short-circuit: three operands, middle false"
  :run-once
  (begin (let ((r 0))
    (if (and (= 1 1) (= 2 9) (= 3 3)) (set! r 1) (set! r 0))
    (check r 0 1))))

(test "and short-circuit: in when context"
  :run-once
  (begin (let ((a 5) (b 10) (flag 0))
    (when (and (> a 3) (> b 7)) (set! flag 1))
    (check flag 1 1))))

(test "and short-circuit: in when, first false skips body"
  :run-once
  (begin (let ((a 1) (b 10) (flag 0))
    (when (and (> a 3) (> b 7)) (set! flag 1))
    (check flag 0 1))))

;; --- short-circuit or ---
(test "or short-circuit: first true takes then"
  :run-once
  (begin (let ((r 0))
    (if (or (= 1 1) (= 2 3)) (set! r 10) (set! r 20))
    (check r 10 1))))

(test "or short-circuit: both false takes else"
  :run-once
  (begin (let ((r 0))
    (if (or (= 1 2) (= 3 4)) (set! r 10) (set! r 20))
    (check r 20 1))))

(test "or short-circuit: second true takes then"
  :run-once
  (begin (let ((r 0))
    (if (or (= 1 2) (= 2 2)) (set! r 10) (set! r 20))
    (check r 10 1))))

(test "or short-circuit: in unless, both false runs body"
  :run-once
  (begin (let ((a 1) (b 2) (flag 0))
    (unless (or (> a 5) (> b 5)) (set! flag 1))
    (check flag 1 1))))

;; --- composition ---
(test "not-and: not (and true false) is true"
  :run-once
  (begin (let ((r 0))
    (if (not (and (= 1 1) (= 2 3))) (set! r 1) (set! r 0))
    (check r 1 1))))

; ─── Loops & accumulators ──────────────────────────────────────

(test "conditional accumulation: only even ticks increment flag"
  :ticks 10
  :run-once
  (begin
    (let ((tick-count 0) (flag 0))
      (dotimes (i 10)
        (set! tick-count (+ tick-count 1))
        (when (= (mod tick-count 2) 0)
          (set! flag (+ flag 1)))
        (move random))
      (check tick-count 10 1)
      (check flag 5 2))))

; ─── Let-forwarding safety ─────────────────────────────────

; Regression: conditional set! must not clobber target's old value.
; This is the wall-dir pattern from open2.alisp: (let ((saved dir)) ...
; (set! counter saved)). The set! into counter is unconditional within
; the let body, but the binding's initializer (dir) must not overwrite
; counter's register at binding time if the forwarding is unsafe.
; Here we test the simpler conditional case: when the condition is false,
; target must retain its old value.
(test "let-forwarding: conditional set! preserves target when branch not taken"
  :run-once
  (begin
    (let ((target 42) (x 0))
      (let ((saved x))
        (when (!= saved 0)
          (set! target saved)))
      ; x=0 so when is not taken, target must still be 42
      (check target 42 1))))

