{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist",
    "rootDir": ".",
    "declaration": true,
    "allowJs": true,
    "checkJs": false
  },
  "include": ["./**/*.ts", "./**/*.js"],
  "exclude": ["dist", "node_modules"]
}
