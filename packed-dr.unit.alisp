; ═══════════════════════════════════════════════════════════════
; Packed Dead-Reckoning — Macro Library and Unit Tests
; ═══════════════════════════════════════════════════════════════
;
; Maps are 128×128, so dx/dy fit in a signed 8-bit integer [-128, 127].
; Both are packed into a single 32-bit register:
;
;   bits  7:0   → dx  (signed 8-bit, two's complement)
;   bits 15:8   → dy  (signed 8-bit, two's complement)
;   bits 31:16  → reserved for future use
;
; Directions: N=1  E=2  S=3  W=4
; Tracking convention (displacement from nest, i.e. how far ant has moved):
;   move N → dy -= 1    move E → dx += 1
;   move S → dy += 1    move W → dx -= 1
;
; ── Primitives ──────────────────────────────────────────────
;   (pack-dx! packed dx)        write signed dx into bits 7:0
;   (pack-dy! packed dy)        write signed dy into bits 15:8
;   (unpack-dx! out packed)     extract signed dx from bits 7:0
;   (unpack-dy! out packed)     extract signed dy from bits 15:8
;   (inc-dx! packed)            add 1 to dx byte in-place
;   (dec-dx! packed)            subtract 1 from dx byte in-place
;   (inc-dy! packed)            add 1 to dy byte in-place
;   (dec-dy! packed)            subtract 1 from dy byte in-place
;
; ── High-level macros ───────────────────────────────────────
;   (move-with-tracking-packed dir packed)  wall-checked move; updates packed in-place
;                               38 instructions, 1 scratch reg (r2)
;
;   (home-dir-packed dir packed)  sets dir toward nest from packed dx/dy
;                               34 instructions, 3 scratch regs (r2–r4)
;
; ── Register budget (when both macros are used together) ────
;   r0  dir         (caller-assigned)
;   r1  packed      (caller-assigned)
;   r2  scratch     (tmp byte / unpacked dx)
;   r3  scratch     (unpacked dy; home-dir-packed only)
;   r4  scratch     (abs-dx; home-dir-packed only)
;   ──  ──────────────────────────────────────────────────
;   5 registers consumed, 3 free (r5, r6, r7) for caller use
;   72 instructions for one expansion of each macro
;
; ── Testing note ────────────────────────────────────────────
; MOVE is an action opcode that ends the tick, so displacement
; updates run at the start of the following tick.  Tests that
; exercise move-with-tracking-packed use a done-flag + (move random)
; pattern to fire the tracked move exactly once and prevent the
; program from wrapping (which would re-initialise let-bound registers):
;
;   tick 1: done=0 → when-block → MOVE ends tick
;   tick 2: displacement update → unpack → break → (move random) ends tick
;
; Run with: argc unit packed-dr.unit.alisp
; ═══════════════════════════════════════════════════════════════

; ─── Primitives ──────────────────────────────────────────────

; Pack a signed integer into bits 7:0 of `packed`.
; Clears the low byte first, then ORs in the new value masked to 8 bits.
(defmacro pack-dx! (packed dx)
  (set! packed (and packed 0xFFFFFF00))
  (set! packed (or  packed (and dx 0xFF))))

; Pack a signed integer into bits 15:8 of `packed`.
(defmacro pack-dy! (packed dy)
  (set! packed (and packed 0xFFFF00FF))
  (set! packed (or  packed (lshift (and dy 0xFF) 8))))

; Unpack bits 7:0 into `out` as a signed 8-bit integer.
; Isolate the byte, then sign-extend: if bit 7 is set subtract 256.
(defmacro unpack-dx! (out packed)
  (set! out (and packed 0xFF))
  (when (>= out 128)
    (set! out (- out 256))))

; Unpack bits 15:8 into `out` as a signed 8-bit integer.
(defmacro unpack-dy! (out packed)
  (set! out (and (rshift packed 8) 0xFF))
  (when (>= out 128)
    (set! out (- out 256))))

; Add 1 to the dx field of `packed` (stays in signed 8-bit range).
; Operates directly on the unsigned byte — no sign-extension needed.
; 6 instructions, 1 scratch register.
(defmacro inc-dx! (packed)
  (let ((tmp 0))
    (set! tmp (and packed 0xFF))
    (set! tmp (+ tmp 1))
    (set! tmp (and tmp 0xFF))
    (set! packed (and packed 0xFFFFFF00))
    (set! packed (or packed tmp))))

; Subtract 1 from the dx field of `packed`.
; 6 instructions, 1 scratch register.
(defmacro dec-dx! (packed)
  (let ((tmp 0))
    (set! tmp (and packed 0xFF))
    (set! tmp (- tmp 1))
    (set! tmp (and tmp 0xFF))
    (set! packed (and packed 0xFFFFFF00))
    (set! packed (or packed tmp))))

; Add 1 to the dy field of `packed`.
; 8 instructions, 1 scratch register.
(defmacro inc-dy! (packed)
  (let ((tmp 0))
    (set! tmp (rshift packed 8))
    (set! tmp (and tmp 0xFF))
    (set! tmp (+ tmp 1))
    (set! tmp (and tmp 0xFF))
    (set! tmp (lshift tmp 8))
    (set! packed (and packed 0xFFFF00FF))
    (set! packed (or packed tmp))))

; Subtract 1 from the dy field of `packed`.
; 8 instructions, 1 scratch register.
(defmacro dec-dy! (packed)
  (let ((tmp 0))
    (set! tmp (rshift packed 8))
    (set! tmp (and tmp 0xFF))
    (set! tmp (- tmp 1))
    (set! tmp (and tmp 0xFF))
    (set! tmp (lshift tmp 8))
    (set! packed (and packed 0xFFFF00FF))
    (set! packed (or packed tmp))))

; ─── High-level macros ───────────────────────────────────────

; Move in `dir` with wall check; update packed dx/dy on success.
; Drop-in replacement for forager.alisp move-with-tracking.
(defmacro move-with-tracking-packed (dir packed)
  (unless (= (probe dir) 1)
    (move dir)
    (cond ((= dir 1) (dec-dy! packed))
          ((= dir 2) (inc-dx! packed))
          ((= dir 3) (inc-dy! packed))
          ((= dir 4) (dec-dx! packed)))))

; Set dir toward nest based on packed dx/dy.
; Drop-in replacement for forager.alisp home-dir.
(defmacro home-dir-packed (dir packed)
  (let ((dx 0)
        (dy 0)
        (abs-dx 0))
    (unpack-dx! dx packed)
    (unpack-dy! dy packed)
    (if (< dx 0) (set! abs-dx (- dx)) (set! abs-dx dx))
    (if (< dy 0)
      (begin
        (set! dy (- dy))            ; dy = |dy|, reuses register (MUL -1)
        (if (> dy abs-dx)
          (set! dir 3)              ; |dy| dominates, was negative → south
          (if (> dx 0)
            (set! dir 4)            ; |dx| dominates → west
            (set! dir 2))))         ; |dx| dominates → east
      (if (> dy abs-dx)
        (set! dir 1)                ; |dy| dominates, was positive → north
        (if (> dx 0)
          (set! dir 4)              ; |dx| dominates → west
          (set! dir 2))))))

; ─────────────────────────────────────────────────────────────
; SECTION 1 — pack/unpack round-trips
; ─────────────────────────────────────────────────────────────

(test "round-trip dx=0 dy=0"
  :ticks 1
  :run-once
  (begin
    (let ((packed 0) (xout 0) (yout 0))
      (pack-dx! packed 0)
      (pack-dy! packed 0)
      (unpack-dx! xout packed)
      (unpack-dy! yout packed)))
  (assert-reg-name xout 0)
  (assert-reg-name yout 0))

(test "round-trip dx=1 dy=0"
  :ticks 1
  :run-once
  (begin
    (let ((packed 0) (xout 0) (yout 0))
      (pack-dx! packed 1)
      (pack-dy! packed 0)
      (unpack-dx! xout packed)
      (unpack-dy! yout packed)))
  (assert-reg-name xout 1)
  (assert-reg-name yout 0))

(test "round-trip dx=0 dy=1"
  :ticks 1
  :run-once
  (begin
    (let ((packed 0) (xout 0) (yout 0))
      (pack-dx! packed 0)
      (pack-dy! packed 1)
      (unpack-dx! xout packed)
      (unpack-dy! yout packed)))
  (assert-reg-name xout 0)
  (assert-reg-name yout 1))

(test "round-trip dx=-1 dy=0"
  :ticks 1
  :run-once
  (begin
    (let ((packed 0) (xout 0) (yout 0))
      (pack-dx! packed -1)
      (pack-dy! packed 0)
      (unpack-dx! xout packed)
      (unpack-dy! yout packed)))
  (assert-reg-name xout -1)
  (assert-reg-name yout 0))

(test "round-trip dx=0 dy=-1"
  :ticks 1
  :run-once
  (begin
    (let ((packed 0) (xout 0) (yout 0))
      (pack-dx! packed 0)
      (pack-dy! packed -1)
      (unpack-dx! xout packed)
      (unpack-dy! yout packed)))
  (assert-reg-name xout 0)
  (assert-reg-name yout -1))

(test "round-trip dx=127 dy=0 (positive max)"
  :ticks 1
  :run-once
  (begin
    (let ((packed 0) (xout 0) (yout 0))
      (pack-dx! packed 127)
      (pack-dy! packed 0)
      (unpack-dx! xout packed)
      (unpack-dy! yout packed)))
  (assert-reg-name xout 127)
  (assert-reg-name yout 0))

(test "round-trip dx=0 dy=127 (positive max)"
  :ticks 1
  :run-once
  (begin
    (let ((packed 0) (xout 0) (yout 0))
      (pack-dx! packed 0)
      (pack-dy! packed 127)
      (unpack-dx! xout packed)
      (unpack-dy! yout packed)))
  (assert-reg-name xout 0)
  (assert-reg-name yout 127))

(test "round-trip dx=-128 dy=0 (negative max)"
  :ticks 1
  :run-once
  (begin
    (let ((packed 0) (xout 0) (yout 0))
      (pack-dx! packed -128)
      (pack-dy! packed 0)
      (unpack-dx! xout packed)
      (unpack-dy! yout packed)))
  (assert-reg-name xout -128)
  (assert-reg-name yout 0))

(test "round-trip dx=0 dy=-128 (negative max)"
  :ticks 1
  :run-once
  (begin
    (let ((packed 0) (xout 0) (yout 0))
      (pack-dx! packed 0)
      (pack-dy! packed -128)
      (unpack-dx! xout packed)
      (unpack-dy! yout packed)))
  (assert-reg-name xout 0)
  (assert-reg-name yout -128))

(test "round-trip dx=42 dy=-99 (mixed signs)"
  :ticks 1
  :run-once
  (begin
    (let ((packed 0) (xout 0) (yout 0))
      (pack-dx! packed 42)
      (pack-dy! packed -99)
      (unpack-dx! xout packed)
      (unpack-dy! yout packed)))
  (assert-reg-name xout 42)
  (assert-reg-name yout -99))

(test "round-trip dx=-99 dy=42 (mixed signs, swapped)"
