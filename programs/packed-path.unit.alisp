; ═══════════════════════════════════════════════════════════════
; 8-Direction RLE Path — Unit Tests
; ═══════════════════════════════════════════════════════════════
;
; Run with: argc unit programs/packed-path.unit.alisp
; ═══════════════════════════════════════════════════════════════

(include "./packed-path.inc.alisp")

; ─────────────────────────────────────────────────────────────
; SECTION 1 — Direction helpers
; ─────────────────────────────────────────────────────────────

(test "dir8-move1: N → ISA N(1)"
  :run-once
  (begin
    (let ((out 0))
      (dir8-move1! out DIR_N)
      (assert! (= out 1) 1))))

(test "dir8-move1: E → ISA E(2)"
  :run-once
  (begin
    (let ((out 0))
      (dir8-move1! out DIR_E)
      (assert! (= out 2) 1))))

(test "dir8-move1: S → ISA S(3)"
  :run-once
  (begin
    (let ((out 0))
      (dir8-move1! out DIR_S)
      (assert! (= out 3) 1))))

(test "dir8-move1: W → ISA W(4)"
  :run-once
  (begin
    (let ((out 0))
      (dir8-move1! out DIR_W)
      (assert! (= out 4) 1))))

(test "dir8-move1: NE → ISA N(1)"
  :run-once
  (begin
    (let ((out 0))
      (dir8-move1! out DIR_NE)
      (assert! (= out 1) 1))))

(test "dir8-move2: NE → ISA E(2)"
  :run-once
  (begin
    (let ((out 0))
      (dir8-move2! out DIR_NE)
      (assert! (= out 2) 1))))

(test "dir8-move2: N → 0 (cardinal, no second move)"
  :run-once
  (begin
    (let ((out 99))
      (dir8-move2! out DIR_N)
      (assert! (= out 0) 1))))

(test "dir8-move1: SE → ISA E(2), move2: SE → ISA S(3)"
  :run-once
  (begin
    (let ((m1 0) (m2 0))
      (dir8-move1! m1 DIR_SE)
      (dir8-move2! m2 DIR_SE)
      (assert! (= m1 2) 1)
      (assert! (= m2 3) 2))))

(test "dir8-move1: SW → ISA S(3), move2: SW → ISA W(4)"
  :run-once
  (begin
    (let ((m1 0) (m2 0))
      (dir8-move1! m1 DIR_SW)
      (dir8-move2! m2 DIR_SW)
      (assert! (= m1 3) 1)
      (assert! (= m2 4) 2))))

(test "dir8-move1: NW → ISA W(4), move2: NW → ISA N(1)"
  :run-once
  (begin
    (let ((m1 0) (m2 0))
      (dir8-move1! m1 DIR_NW)
      (dir8-move2! m2 DIR_NW)
      (assert! (= m1 4) 1)
      (assert! (= m2 1) 2))))

; ─────────────────────────────────────────────────────────────
; SECTION 2 — reverse-dir8!
; ─────────────────────────────────────────────────────────────

(test "reverse N → S"
  :run-once
  (begin
    (let ((d DIR_N))
      (reverse-dir8! d)
      (assert! (= d DIR_S) 1))))

(test "reverse NE → SW"
  :run-once
  (begin
    (let ((d DIR_NE))
      (reverse-dir8! d)
      (assert! (= d DIR_SW) 1))))

(test "reverse E → W"
  :run-once
  (begin
    (let ((d DIR_E))
      (reverse-dir8! d)
      (assert! (= d DIR_W) 1))))

(test "reverse SE → NW"
  :run-once
  (begin
    (let ((d DIR_SE))
      (reverse-dir8! d)
      (assert! (= d DIR_NW) 1))))

(test "reverse S → N"
  :run-once
  (begin
    (let ((d DIR_S))
      (reverse-dir8! d)
      (assert! (= d DIR_N) 1))))

(test "reverse SW → NE"
  :run-once
  (begin
    (let ((d DIR_SW))
      (reverse-dir8! d)
      (assert! (= d DIR_NE) 1))))

(test "reverse W → E"
  :run-once
  (begin
    (let ((d DIR_W))
      (reverse-dir8! d)
      (assert! (= d DIR_E) 1))))

(test "reverse NW → SE"
  :run-once
  (begin
    (let ((d DIR_NW))
      (reverse-dir8! d)
      (assert! (= d DIR_SE) 1))))

(test "double reverse is identity"
  :run-once
  (begin
    (let ((d DIR_NE))
      (reverse-dir8! d)
      (reverse-dir8! d)
      (assert! (= d DIR_NE) 1))))

; ─────────────────────────────────────────────────────────────
; SECTION 3 — Segment accessors
; ─────────────────────────────────────────────────────────────

(test "seg-dir! extracts direction from segment"
  :run-once
  (begin
    (let ((path 0) (d 0))
      ; Segment with dir=S(2), len=5: (2 << 5) | 5 = 69
      (set! path 69)
      (seg-dir! d path)
      (assert! (= d 2) 1))))

(test "seg-len! extracts length from segment"
  :run-once
  (begin
    (let ((path 0) (l 0))
      ; Segment with dir=S(2), len=5: (2 << 5) | 5 = 69
      (set! path 69)
      (seg-len! l path)
      (assert! (= l 5) 1))))

(test "seg-dir! with direction 7 (NW)"
  :run-once
  (begin
    (let ((path 0) (d 0))
      ; dir=NW(7), len=1: (7 << 5) | 1 = 225
      (set! path 225)
      (seg-dir! d path)
      (assert! (= d 7) 1))))

(test "seg-len! max length 31"
  :run-once
  (begin
    (let ((path 0) (l 0))
      ; dir=N(0), len=31: (0 << 5) | 31 = 31
      (set! path 31)
      (seg-len! l path)
      (assert! (= l 31) 1))))

; ─────────────────────────────────────────────────────────────
; SECTION 4 — move-forward! (creates segments on the fly)
; ─────────────────────────────────────────────────────────────

(test "move-forward on empty path: creates first segment with len=1"
  :ticks 2
  :ant-x 16 :ant-y 16
  (begin
    (let ((path 0) (l 0) (d 0))
      (move-forward! path DIR_E (begin))
      (seg-dir! d path)
      (seg-len! l path)
      (assert! (= d DIR_E) 1)
      (assert! (= l 1) 2)
      (assert! (!= path 0) 3))))

(test "move-forward same dir twice: length increments to 2"
  :ticks 3
  :ant-x 16 :ant-y 16
  (begin
    (let ((path 0) (l 0))
      (move-forward! path DIR_S (begin))
      (move-forward! path DIR_S (begin))
      (seg-len! l path)
      (assert! (= l 2) 1))))

(test "move-forward different dir: pushes new segment"
  :ticks 3
  :ant-x 16 :ant-y 16
  (begin
    (let ((path 0) (d 0))
      (move-forward! path DIR_N (begin))
      (move-forward! path DIR_E (begin))
      (seg-dir! d path)
      (assert! (= d DIR_E) 1))))

(test "move-forward fills 4 segments (different dirs)"
  :ticks 5
  :ant-x 16 :ant-y 16
  (begin
    (let ((path 0))
      (move-forward! path DIR_N (begin))
      (move-forward! path DIR_E (begin))
      (move-forward! path DIR_S (begin))
      (move-forward! path DIR_W (begin))
      ; All 4 slots occupied
      (assert! (!= (and path 0xFF000000) 0) 1))))

(test "move-forward 5th different dir on full path: fails"
  :ticks 5
  :ant-x 16 :ant-y 16
  (begin
    (let ((path 0) (res 0))
      (move-forward! path DIR_N (begin))
      (move-forward! path DIR_E (begin))
      (move-forward! path DIR_S (begin))
      (move-forward! path DIR_W (begin))
      (set! res (move-forward! path DIR_NE (begin)))
      (assert! (= res 0) 1))))

(test "move-forward same dir on full path: extends top segment"
  :ticks 6
  :ant-x 16 :ant-y 16
  (begin
    (let ((path 0) (res 0) (l 0))
      (move-forward! path DIR_N (begin))
      (move-forward! path DIR_E (begin))
      (move-forward! path DIR_S (begin))
      (move-forward! path DIR_W (begin))
      (set! res (move-forward! path DIR_W (begin)))
      (assert! (= res 1) 1)
      (seg-len! l path)
      (assert! (= l 2) 2))))

; ─────────────────────────────────────────────────────────────
; SECTION 5 — move-forward! (cardinal wall checks)
; ─────────────────────────────────────────────────────────────

(test "move-forward N: ant moves north, length increments"
  :ticks 2
  :ant-x 16 :ant-y 16
  (begin
    (let ((path 0) (l 0))
      (move-forward! path DIR_N (begin))
      (seg-len! l path)
      (assert! (= l 1) 1))))

(test "move-forward E: ant moves east"
  :ticks 2
  :ant-x 16 :ant-y 16
  (begin
    (let ((path 0))
      (move-forward! path DIR_E (begin)))))

(test "move-forward twice same dir: length increments to 2"
  :ticks 3
  :ant-x 16 :ant-y 16
  (begin
    (let ((path 0) (l 0))
      (move-forward! path DIR_S (begin))
      (move-forward! path DIR_S (begin))
      (seg-len! l path)
      (assert! (= l 2) 1))))

(test "move-forward into wall: returns 0, path unchanged"
  :ticks 1
  :run-once
  :ant-x 1 :ant-y 16
  (begin
    (let ((path 0) (res 0))
      (set! res (move-forward! path DIR_W (begin)))
      (assert! (= res 0) 1)
      (assert! (= path 0) 2))))

; ─────────────────────────────────────────────────────────────
; SECTION 6 — move-forward! (diagonal)
; ─────────────────────────────────────────────────────────────

(test "move-forward NE: two cardinal moves (N then E)"
  :ticks 3
  :ant-x 16 :ant-y 16
  (begin
    (let ((path 0) (l 0))
      (move-forward! path DIR_NE (begin))
      (seg-len! l path)
      (assert! (= l 1) 1))))

(test "move-forward SE: two cardinal moves (S then E)"
  :ticks 3
  :ant-x 16 :ant-y 16
  (begin
    (let ((path 0) (d 0))
      (move-forward! path DIR_SE (begin))
      (current-heading! d path)
      (assert! (= d DIR_SE) 1))))

; ─────────────────────────────────────────────────────────────
; SECTION 7 — backtrack! (cardinal)
; ─────────────────────────────────────────────────────────────

(test "backtrack single step N: pops segment, path becomes 0"
  :ticks 3
  :ant-x 16 :ant-y 16
  (begin
    (let ((path 0))
      (move-forward! path DIR_N (begin))
      (backtrack! path (begin))
      (assert! (= path 0) 1))))

(test "backtrack 2 steps E: first backtrack decrements, second pops"
  :ticks 5
  :ant-x 16 :ant-y 16
  (begin
    (let ((path 0) (l 0))
      (move-forward! path DIR_E (begin))
      (move-forward! path DIR_E (begin))
      (backtrack! path (begin))
      (seg-len! l path)
      (assert! (= l 1) 1)
      (assert! (!= path 0) 2)
      (backtrack! path (begin))
      (assert! (= path 0) 3))))

(test "backtrack across segments: N then E, backtrack E then N"
  :ticks 5
  :ant-x 16 :ant-y 16
  (begin
    (let ((path 0) (d 0))
      (move-forward! path DIR_N (begin))
      (move-forward! path DIR_E (begin))
      (backtrack! path (begin))
      (assert! (!= path 0) 1)
      (current-heading! d path)
      (assert! (= d DIR_N) 2)
      (backtrack! path (begin))
      (assert! (= path 0) 3))))

; ─────────────────────────────────────────────────────────────
; SECTION 8 — backtrack! (diagonal)
; ─────────────────────────────────────────────────────────────

(test "backtrack single step NE: reverses to SW, pops segment"
  :ticks 5
  :ant-x 16 :ant-y 16
  (begin
    (let ((path 0))
      (move-forward! path DIR_NE (begin))
      (backtrack! path (begin))
      (assert! (= path 0) 1))))

; ─────────────────────────────────────────────────────────────
; SECTION 9 — current-heading!
; ─────────────────────────────────────────────────────────────

(test "current-heading after move-forward N"
  :ticks 2
  :ant-x 16 :ant-y 16
  (begin
    (let ((path 0) (d 0))
      (move-forward! path DIR_N (begin))
      (current-heading! d path)
      (assert! (= d DIR_N) 1))))

(test "current-heading after two different dirs returns latest"
  :ticks 3
  :ant-x 16 :ant-y 16
  (begin
    (let ((path 0) (d 0))
      (move-forward! path DIR_N (begin))
      (move-forward! path DIR_SE (begin))
      (current-heading! d path)
      (assert! (= d DIR_SE) 1))))

; ─────────────────────────────────────────────────────────────
; SECTION 10 — random-nonwall-heading!
; ─────────────────────────────────────────────────────────────

(test "random-nonwall-heading in open space: returns valid 8-way direction"
  :run-once
  :ant-x 16 :ant-y 16
  (begin
    (let ((dir DIR_N))
      (random-nonwall-heading! dir)
      (assert! (!= dir -1) 1))))

(test "random-nonwall-heading at west wall: doesn't return W"
  :ticks 1
  :run-once
  :ant-x 1 :ant-y 16
  (begin
    (let ((dir DIR_E))
      (random-nonwall-heading! dir)
      (assert! (!= dir DIR_W) 1))))

(test "random-nonwall-heading avoids reverse of current direction"
  :ticks 10
  :ant-x 16 :ant-y 16
  (begin
    (let ((dir DIR_N) (i 0))
      ; Run many times — should never return S (reverse of N)
      ; in open space where other options exist
      (while (< i 10)
        (set! dir DIR_N)
        (random-nonwall-heading! dir)
        (assert! (!= dir DIR_S) 1)
        (set! i (+ i 1))))))

(test "random-nonwall-heading can generate diagonal directions"
  :ticks 100
  :ant-x 16 :ant-y 16
  (begin
    ; Run many times and track whether we ever see a diagonal (enc >= 4).
    ; With 7 equally-likely candidates, odds of never seeing a diagonal
    ; in 100 tries is negligible.
    (let ((dir DIR_N) (saw-diag 0) (i 0))
      (while (< i 100)
        (set! dir DIR_N)
        (random-nonwall-heading! dir)
        (when (!= (and dir 4) 0)
          (set! saw-diag 1))
        (set! i (+ i 1)))
      (assert! (= saw-diag 1) 1))))

(test "random-nonwall-heading at NW corner: avoids walled directions"
  :run-once
  :ant-x 1 :ant-y 1
  (begin
    (let ((dir DIR_SE))
      (random-nonwall-heading! dir)
      ; Should not pick N(0), W(3), NE(4), NW(7) — all have walled move1
      ; N(0): move1=N, walled.  W(3): move1=W, walled.
      ; NE(4): move1=N, walled. NW(7): move1=W, walled.
      (assert! (!= dir DIR_N) 1)
      (assert! (!= dir DIR_W) 2)
      (assert! (!= dir DIR_NE) 3)
      (assert! (!= dir DIR_NW) 4))))

(test "random-nonwall-heading: move1 of result is always non-wall"
  :ticks 100
  :ant-x 16 :ant-y 16
  (begin
    ; The critical invariant: after picking a heading, the first cardinal
    ; move (dir8-move1!) must always be the probed-clear direction.
    ; Run 100 times and verify move1 is never a wall.
    (let ((dir DIR_N) (m1 0) (i 0))
      (while (< i 100)
        (set! dir DIR_N)
        (random-nonwall-heading! dir)
        (dir8-move1! m1 dir)
        (assert! (!= (probe m1) 1) 1)
        (set! i (+ i 1))))))

(test "random-nonwall-heading: move1 non-wall at west wall"
  :ticks 100
  :ant-x 1 :ant-y 16
  (begin
    ; At x=1, W is a wall. Any heading picked must have non-wall move1.
    (let ((dir DIR_E) (m1 0) (i 0))
      (while (< i 100)
        (set! dir DIR_E)
        (random-nonwall-heading! dir)
        (dir8-move1! m1 dir)
        (assert! (!= (probe m1) 1) 1)
        (set! i (+ i 1))))))

(test "random-nonwall-heading: move1 non-wall at NW corner"
  :ticks 100
  :ant-x 1 :ant-y 1
  (begin
    ; At (1,1), both N and W are walls. Verify move1 is always clear.
    (let ((dir DIR_SE) (m1 0) (i 0))
      (while (< i 100)
        (set! dir DIR_SE)
        (random-nonwall-heading! dir)
        (dir8-move1! m1 dir)
        (assert! (!= (probe m1) 1) 1)
        (set! i (+ i 1))))))

; ─────────────────────────────────────────────────────────────
; SECTION 11 — Integration: explore then backtrack to start
; ─────────────────────────────────────────────────────────────

(test "move E×3 then backtrack ×3: returns to origin"
  :ticks 10
  :ant-x 16 :ant-y 16
  (begin
    (let ((path 0))
      (move-forward! path DIR_E (begin))
      (move-forward! path DIR_E (begin))
      (move-forward! path DIR_E (begin))
      (backtrack! path (begin))
      (backtrack! path (begin))
      (backtrack! path (begin))
      (assert! (= path 0) 1))))

(test "move N×2, E×2: backtrack all returns to origin"
  :ticks 10
  :ant-x 16 :ant-y 16
  (begin
    (let ((path 0))
      (move-forward! path DIR_N (begin))
      (move-forward! path DIR_N (begin))
      (move-forward! path DIR_E (begin))
      (move-forward! path DIR_E (begin))
      (backtrack! path (begin))
      (backtrack! path (begin))
      (backtrack! path (begin))
      (backtrack! path (begin))
      (assert! (= path 0) 1))))

(test "mixed cardinal and diagonal: NE×1, S×2, backtrack all"
  :ticks 12
  :ant-x 16 :ant-y 16
  (begin
    (let ((path 0))
      (move-forward! path DIR_NE (begin))
      (move-forward! path DIR_S (begin))
      (move-forward! path DIR_S (begin))
      (backtrack! path (begin))
      (backtrack! path (begin))
      (assert! (!= path 0) 1)
      (backtrack! path (begin))
      (assert! (= path 0) 2))))

; ─────────────────────────────────────────────────────────────
; SECTION 12 — Multiple forward moves
; ─────────────────────────────────────────────────────────────

(test "5 forward moves same dir: length is 5"
  :ticks 8
  :ant-x 16 :ant-y 16
  (begin
    (let ((path 0))
      (move-forward! path DIR_S (begin))
      (move-forward! path DIR_S (begin))
      (move-forward! path DIR_S (begin))
      (move-forward! path DIR_S (begin))
      (move-forward! path DIR_S (begin))
      (assert! (= (and path 0x1F) 5) 1))))

; ─────────────────────────────────────────────────────────────
; SECTION 13 — Direction N (0) works correctly
; ─────────────────────────────────────────────────────────────
; Regression: direction 0 must not be confused with empty slot.

(test "move-forward N on empty path: path is non-zero"
  :ticks 2
  :ant-x 16 :ant-y 16
  (begin
    (let ((path 0) (d 0) (l 0))
      (move-forward! path DIR_N (begin))
      (assert! (!= path 0) 1)
      (seg-dir! d path)
      (assert! (= d DIR_N) 2)
      (seg-len! l path)
      (assert! (= l 1) 3))))

(test "move-forward N×2 then different dir: pushes new segment"
  :ticks 4
  :ant-x 16 :ant-y 16
  (begin
    (let ((path 0) (d 0))
      (move-forward! path DIR_N (begin))
      (move-forward! path DIR_N (begin))
      (move-forward! path DIR_E (begin))
      (seg-dir! d path)
      (assert! (= d DIR_E) 1))))

(test "backtrack N: returns to origin"
  :ticks 3
  :ant-x 16 :ant-y 16
  (begin
    (let ((path 0))
      (move-forward! path DIR_N (begin))
      (backtrack! path (begin))
      (assert! (= path 0) 1))))
