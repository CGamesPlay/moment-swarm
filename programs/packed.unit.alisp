  (begin
    (let ((p 0) (out 0))
      (pack-2! p 0)
      (dec-2! p)
      (unpack-2 out p)
      (assert! (= out -1) 1))))

(test "dec-2: 1 → 0"
  :run-once
  (begin
    (let ((p 0) (out 0))
      (pack-2! p 1)
      (dec-2! p)
      (unpack-2 out p)
      (assert! (= out 0) 1))))

(test "dec-2: -127 → -128 (approach negative max)"
