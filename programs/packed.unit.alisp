      (assert! (= out 5) 1))))

(test "dec-1: 5 decrements from 0 → -5"
  :run-once
  (begin
    (let ((p 0) (out 0))
      (dec-1! p) (dec-1! p) (dec-1! p) (dec-1! p) (dec-1! p)
      (unpack-1 out p)
      (assert! (= out -5) 1))))

; ─────────────────────────────────────────────────────────────
