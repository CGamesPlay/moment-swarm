      (pack-3! p 1)
      (unpack-3 out p)
      (assert! (= out 1) 1))))

(test "byte 3: round-trip -1"
  :run-once
  (begin
    (let ((p 0) (out 0))
      (pack-3! p -1)
      (unpack-3 out p)
      (assert! (= out -1) 1))))

(test "byte 3: round-trip 127 (positive max)"
