; ─────────────────────────────────────────────────────────────
; SECTION 5 — mixed-sign round-trips (all four bytes at once)
; ─────────────────────────────────────────────────────────────

(test "all four bytes: 42, -99, 127, -128"
  :run-once
  (begin
    (let ((p 0) (o0 0) (o1 0) (o2 0) (o3 0))
      (pack-0! p 42)
      (pack-1! p -99)
      (pack-2! p 127)
      (pack-3! p -128)
      (unpack-0 o0 p)
      (unpack-1 o1 p)
      (unpack-2 o2 p)
      (unpack-3 o3 p)
      (assert! (= o0 42) 1)
      (assert! (= o1 -99) 2)
      (assert! (= o2 127) 3)
      (assert! (= o3 -128) 4))))

(test "all four bytes: -1, -1, -1, -1"
  :run-once
  (begin
    (let ((p 0) (o0 0) (o1 0) (o2 0) (o3 0))
      (pack-0! p -1)
      (pack-1! p -1)
      (pack-2! p -1)
      (pack-3! p -1)
      (unpack-0 o0 p)
      (unpack-1 o1 p)
      (unpack-2 o2 p)
      (unpack-3 o3 p)
      (assert! (= o0 -1) 1)
      (assert! (= o1 -1) 2)
      (assert! (= o2 -1) 3)
      (assert! (= o3 -1) 4))))

(test "all four bytes: 127, -128, 127, -128 (both extremes)"
  :run-once
  (begin
    (let ((p 0) (o0 0) (o1 0) (o2 0) (o3 0))
      (pack-0! p 127)
      (pack-1! p -128)
      (pack-2! p 127)
      (pack-3! p -128)
      (unpack-0 o0 p)
      (unpack-1 o1 p)
      (unpack-2 o2 p)
      (unpack-3 o3 p)
      (assert! (= o0 127) 1)
      (assert! (= o1 -128) 2)
      (assert! (= o2 127) 3)
      (assert! (= o3 -128) 4))))

; ─────────────────────────────────────────────────────────────
; SECTION 6 — field isolation (no cross-byte bleed)
; ─────────────────────────────────────────────────────────────

(test "pack-0 does not disturb byte 1"
  :run-once
  (begin
    (let ((p 0) (out 0))
      (pack-1! p 55)
      (pack-0! p -33)
      (unpack-1 out p)
      (assert! (= out 55) 1))))

(test "pack-1 does not disturb byte 0"
  :run-once
  (begin
    (let ((p 0) (out 0))
      (pack-0! p -33)
      (pack-1! p 55)
      (unpack-0 out p)
      (assert! (= out -33) 1))))

(test "pack-2 does not disturb bytes 0 and 1"
  :run-once
  (begin
    (let ((p 0) (o0 0) (o1 0))
      (pack-0! p -11)
      (pack-1! p 22)
      (pack-2! p -33)
      (unpack-0 o0 p)
      (unpack-1 o1 p)
      (assert! (= o0 -11) 1)
      (assert! (= o1 22) 2))))

(test "pack-3 does not disturb bytes 0, 1, 2"
  :run-once
  (begin
    (let ((p 0) (o0 0) (o1 0) (o2 0))
      (pack-0! p 11)
      (pack-1! p -22)
      (pack-2! p 33)
      (pack-3! p -44)
      (unpack-0 o0 p)
      (unpack-1 o1 p)
      (unpack-2 o2 p)
      (assert! (= o0 11) 1)
      (assert! (= o1 -22) 2)
      (assert! (= o2 33) 3))))

(test "overwriting byte 0 leaves bytes 1-3 intact"
  :run-once
  (begin
    (let ((p 0) (o0 0) (o1 0) (o2 0) (o3 0))
      (pack-0! p 10)
      (pack-1! p -20)
      (pack-2! p 30)
      (pack-3! p -40)
      (pack-0! p -99)
      (unpack-0 o0 p)
      (unpack-1 o1 p)
      (unpack-2 o2 p)
      (unpack-3 o3 p)
      (assert! (= o0 -99) 1)
      (assert! (= o1 -20) 2)
      (assert! (= o2 30) 3)
      (assert! (= o3 -40) 4))))

(test "overwriting byte 2 leaves others intact"
  :run-once
  (begin
    (let ((p 0) (o0 0) (o1 0) (o2 0) (o3 0))
      (pack-0! p -10)
      (pack-1! p 20)
      (pack-2! p -30)
      (pack-3! p 40)
      (pack-2! p 99)
      (unpack-0 o0 p)
      (unpack-1 o1 p)
      (unpack-2 o2 p)
      (unpack-3 o3 p)
      (assert! (= o0 -10) 1)
      (assert! (= o1 20) 2)
      (assert! (= o2 99) 3)
      (assert! (= o3 40) 4))))

; ─────────────────────────────────────────────────────────────
; SECTION 7 — inc/dec byte 0
; ─────────────────────────────────────────────────────────────

(test "inc-0: 0 → 1"
  :run-once
  (begin
    (let ((p 0) (out 0))
      (pack-0! p 0)
      (inc-0! p)
      (unpack-0 out p)
      (assert! (= out 1) 1))))

(test "inc-0: -1 → 0 (crosses zero)"
  :run-once
  (begin
    (let ((p 0) (out 0))
      (pack-0! p -1)
      (inc-0! p)
      (unpack-0 out p)
      (assert! (= out 0) 1))))

(test "inc-0: 126 → 127 (approach positive max)"
  :run-once
  (begin
    (let ((p 0) (out 0))
      (pack-0! p 126)
      (inc-0! p)
      (unpack-0 out p)
      (assert! (= out 127) 1))))

(test "dec-0: 0 → -1 (crosses zero)"
  :run-once
  (begin
    (let ((p 0) (out 0))
      (pack-0! p 0)
      (dec-0! p)
      (unpack-0 out p)
      (assert! (= out -1) 1))))

(test "dec-0: 1 → 0"
  :run-once
  (begin
    (let ((p 0) (out 0))
      (pack-0! p 1)
      (dec-0! p)
      (unpack-0 out p)
      (assert! (= out 0) 1))))

(test "dec-0: -127 → -128 (approach negative max)"
  :run-once
  (begin
    (let ((p 0) (out 0))
      (pack-0! p -127)
      (dec-0! p)
      (unpack-0 out p)
      (assert! (= out -128) 1))))

(test "inc-0: 5 increments from 0 → 5"
  :run-once
  (begin
    (let ((p 0) (out 0))
      (inc-0! p) (inc-0! p) (inc-0! p) (inc-0! p) (inc-0! p)
      (unpack-0 out p)
      (assert! (= out 5) 1))))

(test "dec-0: 5 decrements from 0 → -5"
  :run-once
  (begin
    (let ((p 0) (out 0))
      (dec-0! p) (dec-0! p) (dec-0! p) (dec-0! p) (dec-0! p)
      (unpack-0 out p)
      (assert! (= out -5) 1))))

