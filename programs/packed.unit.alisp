(test "byte 2: round-trip 1"
  :run-once
  (begin
    (let ((p 0) (out 0))
      (pack-2! p 1)
      (unpack-2 out p)
      (assert! (= out 1) 1))))

(test "byte 2: round-trip -1"
  :run-once
  (begin
    (let ((p 0) (out 0))
      (pack-2! p -1)
