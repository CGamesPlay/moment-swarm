; ═══════════════════════════════════════════════════════════════
; Packed Bytes — Unit Tests (Signed [-128, 127])
; ═══════════════════════════════════════════════════════════════
;
; Tests verify that pack/unpack/inc/dec macros correctly handle
; signed 8-bit values in all four byte positions of a 32-bit
; register.
;
; Run with: argc unit programs/packed.unit.alisp
; ═══════════════════════════════════════════════════════════════

(include "./packed.inc.alisp")

; ─────────────────────────────────────────────────────────────
; SECTION 1 — pack/unpack round-trips (byte 0)
; ─────────────────────────────────────────────────────────────

(test "byte 0: round-trip 0"
  :run-once
  (begin
    (let ((p 0) (out 0))
      (pack-0! p 0)
      (unpack-0 out p)
      (assert! (= out 0) 1))))

(test "byte 0: round-trip 1"
  :run-once
  (begin
    (let ((p 0) (out 0))
      (pack-0! p 1)
      (unpack-0 out p)
      (assert! (= out 1) 1))))

(test "byte 0: round-trip -1"
  :run-once
  (begin
    (let ((p 0) (out 0))
      (pack-0! p -1)
      (unpack-0 out p)
      (assert! (= out -1) 1))))

(test "byte 0: round-trip 127 (positive max)"
  :run-once
  (begin
    (let ((p 0) (out 0))
      (pack-0! p 127)
      (unpack-0 out p)
      (assert! (= out 127) 1))))

(test "byte 0: round-trip -128 (negative max)"
  :run-once
  (begin
    (let ((p 0) (out 0))
      (pack-0! p -128)
      (unpack-0 out p)
      (assert! (= out -128) 1))))

(test "byte 0: round-trip 42"
  :run-once
  (begin
    (let ((p 0) (out 0))
      (pack-0! p 42)
      (unpack-0 out p)
      (assert! (= out 42) 1))))

(test "byte 0: round-trip -99"
  :run-once
  (begin
    (let ((p 0) (out 0))
      (pack-0! p -99)
      (unpack-0 out p)
      (assert! (= out -99) 1))))

